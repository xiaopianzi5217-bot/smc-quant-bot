{
  "version": "v11_v3_institutional_upgrade",
  "mode": "dry_run",
  "data_mode": "live",
  "exchange": "bitget",
  "symbols": [
    "BTC/USDT",
    "ETH/USDT",
    "SOL/USDT"
  ],
  "symbol_blacklist": [
    "SOL/USDT"
  ],
  "exec_timeframe": "15m",
  "macro_timeframe": "1h",
  "scan_interval_seconds": 45,
  "risk": {
    "leverage": 1,
    "max_open_positions": 4,
    "max_same_direction_positions": 2,
    "max_daily_loss_r": 3.0,
    "max_drawdown_pct": 0.1,
    "max_consecutive_losses": 3,
    "min_rr": 1.5,
    "risk_per_trade": 0.008
  },
  "position_sizing": {
    "enabled": true,
    "grade_risk_multiplier": {
      "S": 1.0,
      "A": 0.5,
      "B": 0.25,
      "C": 0.0
    },
    "observe_grades": [
      "S",
      "A"
    ]
  },
  "strategy_params": {
    "wvf_std_mult": 1.8,
    "min_score_edge": 0.15,
    "score_base_threshold": 3.2,
    "rsi_ob": 72,
    "rsi_os": 28,
    "min_setup_quality": 55,
    "strong_setup_quality": 75
  },
  "strategy_filters": {
    "enabled": true,
    "multi_timeframe_trend": {
      "enabled": true,
      "allow_both": false,
      "block_long_when_exec_red": true,
      "block_short_when_exec_blue": true
    },
    "fib_ote": {
      "enabled": true,
      "min_fib": 0.5,
      "max_fib": 0.88,
      "premium_penalty": 0.5,
      "ote_bonus": 1.3
    },
    "symbol_cooldown": {
      "enabled": true,
      "bars": 1,
      "state_file": "state/strategy_filter_state.json"
    },
    "atr_volatility": {
      "enabled": true,
      "min_atr_pct": 0.0009,
      "max_atr_pct": 0.06
    },
    "volume_confirmation": {
      "enabled": true,
      "soft_min_volume_ratio": 0.75
    },
    "structure_distance": {
      "enabled": false,
      "max_chase_atr": 1.6
    },
    "trading_session": {
      "enabled": false
    },
    "vwap": {
      "enabled": true
    }
  },
  "execution": {
    "order_type": "limit",
    "tp_target": "structural",
    "move_sl_to_be_after_tp1": true,
    "trail_after_tp1": true,
    "trail_atr_mult": 1.1,
    "smart_sl_multiplier": 0.8
  },
  "squeeze_filter": {
    "enabled": true,
    "block_building": false,
    "allow_strong_signal": true,
    "strong_score": 5.5
  },
  "smc_quality": {
    "enabled": true,
    "near_zone_atr_mult": 0.55,
    "sweep_lookback_bars": 8,
    "fvg_lookback_bars": 80,
    "ob_lookback_bars": 20,
    "min_quality_to_trade": 55,
    "prefer_quality_over_quantity": true,
    "notes": "V3严格风控版：强制趋势对齐，严控逆势操作。"
  },
  "telegram": {
    "send_observer": true,
    "send_observer_all": false,
    "send_approved": true
  },
  "v9_kernel": {
    "threshold": 35.0,
    "min_edge": 5.0,
    "ev_threshold": 0.0
  },
  "v565_gate": {
    "enabled": true,
    "min_score": 55.0,
    "min_model_ev": -0.28,
    "hard_block_hours": [4, 6, 7, 23]
  }
}
